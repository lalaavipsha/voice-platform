# ===========================================
# Voice Platform - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# App
APP_NAME="Voice Platform API"
APP_VERSION="0.1.0"
ENVIRONMENT=development
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000

# AWS
AWS_REGION=eu-west-2
AWS_S3_BUCKET=voice-platform-dev-audio

# Amazon Bedrock (LLM)
# Claude 3 Haiku - fast and cheap. Other options:
#   anthropic.claude-3-sonnet-20240229-v1:0 (better quality)
#   anthropic.claude-3-5-sonnet-20241022-v2:0 (best quality)
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_MAX_TOKENS=500
BEDROCK_TEMPERATURE=0.7

# Amazon Polly (TTS)
# Neural voices: Matthew, Joanna, Amy, Brian, Ruth
POLLY_VOICE_ID=Matthew
POLLY_ENGINE=neural
POLLY_OUTPUT_FORMAT=mp3

# Amazon Transcribe (STT)
TRANSCRIBE_LANGUAGE_CODE=en-US

# DynamoDB
DYNAMODB_TABLE=voice-platform-conversations

# Rate Limiting
MAX_AUDIO_SIZE_MB=25
MAX_REQUESTS_PER_MINUTE=20
